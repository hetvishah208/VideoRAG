# Copy to .env and fill in. .env is gitignored — never commit real keys.

# OpenRouter API key (https://openrouter.ai/keys). Free-tier models available.
API_KEY=your_openrouter_key_here

# Optional overrides (defaults shown)
# LLM_MODEL=qwen/qwen2.5-vl-72b-instruct:free
# QDRANT_LOCATION=:memory:
# EMBEDDING_MODEL=clip-ViT-L-14
# TRANSCRIPTION_MODEL=base
# FRAME_RATE=2
# TOP_K=5
# MIN_SCORE=0.7
# ALLOWED_ORIGINS=http://localhost:5173
